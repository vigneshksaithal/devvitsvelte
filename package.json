{
    "private": true,
    "name": "devvit-svelte-template",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "postinstall": "bun run build",
        "build": "vite build",
        "deploy": "bun run build && devvit upload",
        "dev": "concurrently -k -p \"[{name}]\" -n \"BUILD,DEVVIT\" -c \"blue,magenta\" \"vite build --watch\" \"dotenv -e .env -- devvit playtest\"",
        "dev:devvit": "dotenv -e .env -- devvit playtest",
        "login": "devvit login",
        "check": "svelte-check --tsconfig ./src/client/tsconfig.json",
        "launch": "bun run build && bun run deploy && devvit publish",
        "type-check": "tsc --build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@devvit/web": "0.12.15",
        "@hono/node-server": "^1.19.11",
        "@tailwindcss/vite": "^4.2.2",
        "devvit": "0.12.15",
        "hono": "^4.12.9",
        "tailwindcss": "^4.2.2"
    },
    "devDependencies": {
        "@devvit/start": "0.12.15",
        "@devvit/test": "^0.12.15",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "concurrently": "^9.2.1",
        "dotenv-cli": "^11.0.0",
        "svelte": "^5.54.0",
        "svelte-check": "^4.4.5",
        "typescript": "^5.9.3",
        "vite": "8.0.1",
        "vitest": "^4.1.0"
    },
    "packageManager": "bun@1.3.11"
}