{
    "private": true,
    "name": "devvit-svelte-template",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "postinstall": "bun run build",
        "build": "vite build",
        "deploy": "bun run build && devvit upload",
        "dev": "concurrently -k -p \"[{name}]\" -n \"BUILD,DEVVIT\" -c \"blue,magenta\" \"vite build --watch\" \"dotenv -e .env -- devvit playtest\"",
        "dev:devvit": "dotenv -e .env -- devvit playtest",
        "login": "devvit login",
        "check": "svelte-check --tsconfig ./src/client/tsconfig.json",
        "launch": "bun run build && bun run deploy && devvit publish",
        "type-check": "tsc --build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@devvit/web": "0.13.5",
        "@hono/node-server": "^2.0.6",
        "@tailwindcss/vite": "^4.3.1",
        "devvit": "0.13.5",
        "hono": "^4.12.27",
        "tailwindcss": "^4.3.1"
    },
    "devDependencies": {
        "@devvit/start": "0.13.5",
        "@devvit/test": "^0.13.5",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "concurrently": "^10.0.3",
        "dotenv-cli": "^11.0.0",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "typescript": "6.0.3",
        "vite": "8.1.0",
        "vitest": "^4.1.9"
    },
    "packageManager": "bun@1.3.13"
}
