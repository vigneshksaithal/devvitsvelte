{
  "mcpServers": {
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp",
      "autoApprove": [
        "list-sections"
      ]
    },
    "devvit": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@devvit/mcp"
      ],
      "autoApprove": [
        "devvit_search"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "disabled": false,
      "autoApprove": [
        "sequentialthinking"
      ]
    }
  }
}